trovare il numero di attori per ogni film mostrando anche il titolo nel risultato
usare sempre l'identificatore degli oggetti nelle aggregazioni. Aggregare solo per il titolo rischia considerare con un unico film anche pellicole che hanno stesso titolo ma id diverso
db.movie.aggregate(
[
    {
        "$unwind": "$crew"
    },
    {
        "$match": {
            "crew.role": "actor"
        }
    },
    {
        "$group": {
            "_id": {
                "movie": "$_id",
                "title": "$title"
            },
            "numero attori": { "$sum": 1
            }
        }
    },
    {
        "$project": {
            "_id": 0,
            "titolo": "$_id.title",
            "numero attori": 1
        }
    }
])

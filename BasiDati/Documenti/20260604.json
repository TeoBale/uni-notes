calcoliamo la media dei film di DiCaprio usando count e sum
db.movie.aggregate(
[
    {
        "$match": {
            "crew": {
                "$elemMatch": {
                    "give_name": "Leonardo DiCaprio",
                    "role": "actor"
                }
            }
        }
    },
    {
        "$match": {
            "length": {
                "$exists": true
            }
        }
    },
    {
        "$group": {
            "_id": null,
            "durata complessiva": {
                "$sum": "$length"
            },
            "numero film": {
                "$sum": 1
            },
            "durata media": {
                "$avg": "$length"
            }
        }
    },
    {
        "$project": {
            "_id": 0,
            "attore": "Leonardo DiCaprio",
            "durata media": 1,
            "durata media con divide": {
                "$divide": [
                    "$durata complessiva",
                    "$numero film"
                ]
            }
        }
    }
])


            }
        }
    }
])

trovare le recensioni prodotte nel mese di novembre 2017
db.movie.aggregate([
    {
        "$match": {
            "ratings": {
                "$elemMatch": {
                    "$and": [
                        {
                            "rating_date": {
                                "$gte": ISODate("2017-11-01")
                            }
                        },
                        {
                            "rating_date": {
                                "$lte": ISODate("2017-11-30")
                            }
                        }
                    ]
                }
            }
        }
    },
    {
        "$project": { "ratings": 1
        }
    }
])

contare le recensioni prodotte nel mese di novembre 2017
questa soluzione conta i film con almeno una recensione in novembre 2017. Se un film ha più recensioni in novembre 2017 viene contato una volta sola perchè il documento è uno solo
db.movie.aggregate([
    {
        "$match": {
            "ratings": {
                "$elemMatch": {
                    "$and": [
                        {
                            "rating_date": {
                                "$gte": ISODate("2017-11-01")
                            }
                        },
                        {
                            "rating_date": {
                                "$lte": ISODate("2017-11-30")
                            }
                        }
                    ]
                }
            }
        }
    },
    {
        "$group": {
            "_id": null,
            "totale recensioni": {
                "$sum": 1
            }
        }
    }
])

una soluzione corretta (cioè che conta le recensioni e non i film)
db.movie.aggregate([
    {
        "$unwind": "$ratings"
    },
    {
        "$match": {
            "$and": [
                {
                    "ratings.rating_date": {
                        "$gte": ISODate("2017-11-01")
                    }
                },
                {
                    "ratings.rating_date": {
                        "$lte": ISODate("2017-11-30")
                    }
                }
            ]
        }
    },
    {
        "$group": {
            "_id": null,
            "totale recensioni": {
                "$sum": 1
            }
        }
    }
])


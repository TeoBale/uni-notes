trovare la numerosità della crew dei film in cui recita DiCaprio
$size funziona solo se applicato a array 
https: //www.mongodb.com/docs/manual/reference/operator/aggregation/size/
db.movie.aggregate(
[
    {
        "$match": {
            "crew": {
                "$elemMatch": {
                    "give_name": "Leonardo DiCaprio",
                    "role": "actor"
                }
            }
        }
    },
    {
        "$project": {
            "_id": 0,
            "title": 1,
            "year": 1,
            "length": 1,
            "numerosità crew": {
                "$size": "$crew"
            }
        }
    }
])

uso $type per escludere i documenti in cui crew non è array 
https: //www.mongodb.com/docs/manual/reference/operator/query/type/
db.movie.aggregate(
[
    {
        "$match": {
            "crew": {
                "$elemMatch": {
                    "give_name": "Leonardo DiCaprio",
                    "role": "actor"
                }
            }
        }
    },
    {
        "$match": {
            "crew": {
                "$type": "array"
            }
        }
    },
    {
        "$project": {
            "_id": 0,
            "title": 1,
            "year": 1,
            "length": 1,
            "numerosità crew": {
                "$size": "$crew"
            }
        }
    }
])


